# =============================================================================
# 天问-AGI 环境变量配置模板
# =============================================================================
# 复制此文件为 .env 并填入实际值
# cp .env.example .env
#
# 安全提醒: .env 文件已在 .gitignore 中排除，切勿提交到版本控制
# =============================================================================

# --- 运行模式 ---
# 调试模式: true=开启(开发环境), false=关闭(生产环境必须为false)
DEBUG=false

# --- API 认证 ---
# API Key: 用于保护 /api/chat 等敏感端点
# 生产环境必须设置强随机字符串
# 生成方式: python -c "import secrets; print(secrets.token_urlsafe(32))"
API_KEY=

# --- CORS 跨域配置 ---
# 允许的跨域域名，多个用逗号分隔
# 生产环境: https://your-frontend.pages.dev
# 开发环境: 留空则允许所有域名(仅DEBUG=true时生效)
CORS_ORIGINS=

# --- LLM API 配置 ---
# DeepSeek API (推理引擎)
DEEPSEEK_API_KEY=

# MiniMax API (对话接口)
MINIMAX_API_KEY=
MINIMAX_GROUP_ID=
MINIMAX_MODEL=MiniMax-Text-01

# --- 数据库配置 ---
# ChromaDB 向量数据库
CHROMA_HOST=vector-db
CHROMA_PORT=8000

# Neo4j 图数据库
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=

# --- 速率限制 ---
# 时间窗口(秒)
RATE_LIMIT_WINDOW=60
# 窗口内最大请求数
RATE_LIMIT_MAX_REQUESTS=30

# --- 日志 ---
# 日志级别: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# --- 服务端口 ---
# Railway 等平台会自动注入 PORT 环境变量
PORT=5000
